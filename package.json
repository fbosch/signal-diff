{
  "name": "signal-diff",
  "version": "0.0.0",
  "private": true,
  "description": "Concept-first diff review CLI for TypeScript repositories",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "lint": "biome check .",
    "pretest": "pnpm build",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@types/node": "^24.9.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
