{
  "name": "signal-diff",
  "version": "1.0.0",
  "private": true,
  "description": "JSON-first review CLI for TypeScript repositories",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bench": "tsx benchmarks/run.ts",
    "bench:baseline:update": "tsx benchmarks/run.ts --update-baseline --json",
    "bench:ci": "tsx benchmarks/run.ts --warmup=1 --samples=8 --iterations=25 --json",
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "lint": "biome check .",
    "prebench": "pnpm build",
    "prebench:baseline:update": "pnpm build",
    "prebench:ci": "pnpm build",
    "pretest": "pnpm build",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc -b --pretty false",
    "verify": "pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@types/node": "^24.9.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
